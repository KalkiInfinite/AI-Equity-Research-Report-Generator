# Copy this file to .env and fill in the key for whichever LLM you want to use.
# You only need the key for the provider your EXTRACTION_MODEL belongs to.

# Pick any model (LiteLLM routes it to the right provider):
#   anthropic/claude-sonnet-4-6      -> needs ANTHROPIC_API_KEY
#   gpt-4o                           -> needs OPENAI_API_KEY
#   gemini/gemini-1.5-pro            -> needs GEMINI_API_KEY
#   mistral/mistral-large-latest     -> needs MISTRAL_API_KEY
#   ollama/llama3                    -> local, no key needed
EXTRACTION_MODEL=anthropic/claude-sonnet-4-6

# Set the key that matches your model (only one is required):
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...
