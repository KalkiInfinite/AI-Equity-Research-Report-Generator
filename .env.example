# Copy this file to .env and fill in the key for whichever LLM you want to use.
# You only need the key for the provider your EXTRACTION_MODEL belongs to.

# Two models for different tasks:
#   EXTRACTION_MODEL = fast model for document extraction (deepseek-chat is fast)
#   CHAT_MODEL       = smart model for chatbot reasoning (deepseek-v4-pro is best)
#
# Available options:
#   deepseek/deepseek-chat            -> fast, good for structured extraction
#   deepseek/deepseek-v4-pro          -> best reasoning, use for chat
#   deepseek/deepseek-v4-flash        -> balanced speed/reasoning
#   deepseek/deepseek-reasoner        -> deepest reasoning, slowest
EXTRACTION_MODEL=deepseek/deepseek-chat
CHAT_MODEL=deepseek/deepseek-v4-pro

# Set the key that matches your model (only one is required):
DEEPSEEK_API_KEY=your-deepseek-key-here
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...

# InsightSentry RapidAPI key (for live market data enrichment)
INSIGHTSENTRY_API_KEY=your-rapidapi-key-here
